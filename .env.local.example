# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── API Auth ──
# Shared secret — include as Bearer token in Authorization header
# Both Wes and Gibb use the same key from their Claude sessions
DISCOVERY_HUB_API_KEY=generate-a-strong-key-here

# ── Anthropic (for auto-digest) ──
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Optional ──
# Comma-separated origins if you want to restrict CORS
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
